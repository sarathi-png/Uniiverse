    "@types/express": "^5.0.6",
    "@types/http-proxy": "^1.17.17",
    "@types/node": "22.19.17",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@types/webtorrent": "^0.110.1",
    "@vitejs/plugin-react": "5.1.1",
