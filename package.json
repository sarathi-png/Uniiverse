    "dubmv:popular": "tsx server/scripts/popular.ts",
    "dubmv:map": "tsx server/scripts/map-popular.ts",
    "dubmv:batch": "tsx server/scripts/batch-cache.ts",
    "vivamax:catalog": "tsx server/scripts/vivamax-catalog.ts",
    "vivamax:embeds": "tsx server/scripts/vivamax-embeds.ts",
    "start": "tsx server/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.14",
    "axios": "^1.16.1",
    "cheerio": "^1.2.0",
    "clsx": "2.1.1",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.22.2",
    "framer-motion": "^12.40.0",
    "hls.js": "^1.6.16",
    "node-cache": "^5.1.2",
